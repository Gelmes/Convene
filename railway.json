{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @convene/db generate && pnpm --filter @convene/web build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @convene/db migrate:deploy && pnpm --filter @convene/web start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
