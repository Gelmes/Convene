// Convene — Phase 0 schema
// Tenant = Organization. Every tenant-scoped row carries organizationId and is
// only ever reached through the org-scoped data-access layer (src/tenant.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Tenant + identity
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  planId    String? // billing seam — nullable until Phase 6
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships     Membership[]
  participants    Participant[]
  events          Event[]
  registrations   EventRegistration[]
  healthReadings  HealthReading[]
  formTemplates   FormTemplate[]
  formSubmissions FormSubmission[]
  auditLogs       AuditLog[]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
  participant Participant? // a user may also be a participant (claimed record)
}

model Membership {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  role           Role             @default(STAFF)
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Participants (org-owned; account optional — "add on the spot", claim later)
// ---------------------------------------------------------------------------

model Participant {
  id             String    @id @default(cuid())
  organizationId String
  userId         String?   @unique // set when the participant claims an account
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  dateOfBirth    DateTime?
  consentAt      DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  registrations   EventRegistration[]
  healthReadings  HealthReading[]
  formSubmissions FormSubmission[]

  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Events (Phase 1)
// ---------------------------------------------------------------------------

model Event {
  id                   String      @id @default(cuid())
  organizationId       String
  title                String
  description          String?
  location             String?
  startsAt             DateTime
  endsAt               DateTime?
  status               EventStatus @default(UPCOMING)
  publicRegistration   Boolean     @default(false)
  intakeFormTemplateId String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  intakeForm      FormTemplate?       @relation("EventIntakeForm", fields: [intakeFormTemplateId], references: [id], onDelete: SetNull)
  registrations   EventRegistration[]
  healthReadings  HealthReading[]
  formSubmissions FormSubmission[]

  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Custom intake forms (Phase 2)
// ---------------------------------------------------------------------------

model FormTemplate {
  id             String     @id @default(cuid())
  organizationId String
  name           String
  description    String?
  version        Int        @default(1)
  status         FormStatus @default(DRAFT)
  questions      Json       @default("[]") // validated by @convene/schemas formQuestionsSchema
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submissions  FormSubmission[]
  intakeEvents Event[]          @relation("EventIntakeForm")

  @@index([organizationId])
}

model FormSubmission {
  id                String   @id @default(cuid())
  organizationId    String
  formTemplateId    String
  formVersion       Int
  participantId     String
  eventId           String?
  filledBy          FilledBy
  submittedByUserId String?
  answers           Json // self-describing: [{questionId, label, value}]
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  formTemplate FormTemplate @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)
  participant  Participant  @relation(fields: [participantId], references: [id], onDelete: Cascade)
  event        Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([participantId])
  @@index([formTemplateId])
}

enum FormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum FilledBy {
  PARTICIPANT
  HOST
}

model EventRegistration {
  id             String             @id @default(cuid())
  organizationId String
  eventId        String
  participantId  String
  status         RegistrationStatus @default(REGISTERED)
  source         RegistrationSource @default(HOST_ADDED)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participant  Participant  @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([eventId, participantId])
  @@index([organizationId])
  @@index([eventId])
}

enum EventStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum RegistrationStatus {
  REGISTERED
  CHECKED_IN
  ATTENDED
  NO_SHOW
}

enum RegistrationSource {
  SELF
  HOST_ADDED
  INVITE
}

// ---------------------------------------------------------------------------
// Health data — isolated, audited, encryptable (design-for-clinical-later)
// ---------------------------------------------------------------------------

model HealthReading {
  id             String   @id @default(cuid())
  organizationId String
  participantId  String
  eventId        String? // optional link to the event where it was taken
  systolic       Int
  diastolic      Int
  pulse          Int?
  note           String? // runs through the encryption seam (packages/core crypto)
  takenByUserId  String?
  takenAt        DateTime @default(now())
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  participant  Participant  @relation(fields: [participantId], references: [id], onDelete: Cascade)
  event        Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([participantId])
  @@index([eventId])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorUserId    String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([entityType, entityId])
}

enum Role {
  OWNER
  ADMIN
  FACILITATOR
  STAFF
}

enum MembershipStatus {
  ACTIVE
  INVITED
  DISABLED
}

// ---------------------------------------------------------------------------
// Auth.js adapter models
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
