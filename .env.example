# ---- Database (Railway Postgres) ----
# Railway injects DATABASE_URL for the Postgres plugin. Locally, paste the
# connection string from the Railway service, or run a local Postgres.
DATABASE_URL="postgresql://user:password@localhost:5432/vitalgather?schema=public"

# ---- Auth.js ----
# Generate one: `npx auth secret` or `openssl rand -base64 32`
AUTH_SECRET="replace-me-with-a-long-random-string"
# Public URL of the app (Railway sets this to your deploy URL in prod)
AUTH_URL="http://localhost:3000"

# ---- Email (magic links via Resend) ----
# Leave RESEND_API_KEY empty in dev: magic links are printed to the server console.
RESEND_API_KEY=""
EMAIL_FROM="Vitalgather <onboarding@resend.dev>"

# ---- Health-data encryption seam ----
# "off"  -> wellness mode: sensitive free-text stored as plaintext (relies on DB at-rest encryption)
# "on"   -> clinical mode: app-level AES-256-GCM encryption of sensitive free-text
ENCRYPTION_MODE="off"
# Required only when ENCRYPTION_MODE="on". Use a long random secret.
ENCRYPTION_KEY=""
